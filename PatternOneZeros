
package pattern;

import java.util.Scanner;

public class OneZero {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of rows: ");
        int n = sc.nextInt();

        for(int i = 0; i < n; i++) {
            for(int j = 0; j <= i; j++) {
                System.out.print((i + j) % 2 == 0 ? 1 : 0);
            }
            System.out.println();
        }

        sc.close();
    }
}
